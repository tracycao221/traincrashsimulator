# Google Analytics
NEXT_PUBLIC_ANALYTICS_ID=

# Google AdSense public onboarding values.
# Use the ca-pub-* client id for the site-wide script.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# Optional bootstrap/build helper for /ads.txt:
# google.com, pub-XXXXXXXXXXXXXXXX, DIRECT, f08c47fec0942fa0
ADSENSE_ADS_TXT_LINE=
ADSENSE_PUBLISHER_ID=

# Adsterra public runtime values.
# The private publisher API key belongs only in CI/local secret storage as ADSTERRA_PUBLISHER_API_KEY.
